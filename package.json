{
  "name": "Decentraland",
  "private": true,
  "version": "1.16.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build-ui": "tsc && vite build",
    "build-core": "tauri build",
    "build": "npm run build-ui && npm run build-core",
    "preview": "vite preview",
    "tauri": "tauri",
    "format-ui": "npx prettier --write '**/*.{js,mjs,cjs,jsx,ts,ODmts,cts,tsx}'",
    "format-tauri": "cd src-tauri && cargo fmt -- --check --verbose",
    "format-core": "cd core && cargo fmt -- --check --verbose",
    "format-src-auto-auth": "cd src-auto-auth && cargo fmt -- --check --verbose",
    "format": "npm run format-ui && npm run format-tauri && npm run format-core && npm run format-src-auto-auth",
    "analyze-tauri": "cd src-tauri && cargo clippy --all-targets --all-features -- -D warnings",
    "analyze-core": "cd core && cargo clippy --all-targets --all-features -- -D warnings",
    "analyze-src-auto-auth": "cd src-auto-auth && cargo clippy --all-targets --all-features -- -D warnings",
    "analyze": "npm run analyze-tauri && npm run analyze-core && npm run analyze-src-auto-auth"
  },
  "dependencies": {
    "@sentry/react": "^8.29.0",
    "@sentry/vite-plugin": "^2.22.4",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-deep-link": "^2.2.1",
    "@tauri-apps/plugin-process": "^2.2.1",
    "@tauri-apps/plugin-updater": "^2.7.0",
    "decentraland-ui2": "^0.12.1",
    "path": "^0.12.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "url": "^0.11.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/jest": "^29.5.12",
    "@types/node": "20.14.8",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}