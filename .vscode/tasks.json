{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ui:dev",
      "type": "shell",
      "isBackground": true,
      "command": "npm",
      "args": [
        "run",
        "dev"
      ],
      "options" : {
        "env": {
          "VITE_AWS_S3_BUCKET_PUBLIC_URL": "https://explorer-artifacts.decentraland.org"
        }
      },
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
            "regexp": "."
        },
        "background": {
            "activeOnStart": true,
            "beginsPattern": "VITE",
            "endsPattern": "Local:"
        }
      }
    }
  ]
}